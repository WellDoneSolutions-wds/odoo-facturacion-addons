<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Grupo de la app NE Express. Implica el grupo Contable de Odoo
            (account.group_account_user), del que HEREDA los permisos para
            crear/editar facturas, pagos, clientes y productos + la
            reconciliación que usan retención/percepción.

            Aislamiento por compañía/RUC: lo aplican las reglas multi-compañía
            NATIVAS de Odoo (filtran account.move/account.payment/res.partner/
            product por company_id ∈ compañías permitidas, y manejan
            correctamente los registros compartidos company_id=False). NO se
            redefinen aquí para no romper ese manejo de compartidos; para el
            SaaS multi-RUC basta dar de alta 1 res.company por RUC y atar cada
            usuario emisor a la suya.
        -->
        <record id="group_l10n_pe_ne_emisor" model="res.groups">
            <field name="name">Emisor NE Express</field>
            <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="api_key_duration">365</field>
            <field name="comment">Puede emitir comprobantes electrónicos y gestionar clientes/productos vía la API de NE Express (controller /ne/api). Hereda el grupo Contable; el aislamiento por RUC lo aplican las reglas multi-compañía nativas. Para anular hace falta además el grupo "Anulación de comprobantes".</field>
        </record>

        <!--
            Anular es irreversible y tiene efecto ante SUNAT (RA/RC): se separa de la
            emisión para que un cajero pueda facturar sin poder dar de baja. IMPLICA el
            grupo Emisor (quien anula también emite), así que basta con asignar este.

            Los emisores que YA existían conservan la anulación: la migración
            pre-19.0.1.4.0 los mete en este grupo. Quitárselo es decisión del admin,
            no un efecto colateral del upgrade.
        -->
        <record id="group_l10n_pe_ne_anulacion" model="res.groups">
            <field name="name">Anulación de comprobantes NE Express</field>
            <field name="implied_ids" eval="[(4, ref('group_l10n_pe_ne_emisor'))]"/>
            <field name="comment">Puede comunicar la baja de un comprobante ante SUNAT (RA/RC) vía /ne/api/anular. Implica el grupo Emisor NE Express.</field>
        </record>

        <!--
            Aislamiento multi-compañía del modelo propio l10n_pe_ne.gasto (regla
            GLOBAL: aplica a todos). Maneja company_id=False (compartidos) igual
            que las reglas nativas. Sin esto, los gastos serían visibles entre RUC.
        -->
        <record id="rule_l10n_pe_ne_gasto_company" model="ir.rule">
            <field name="name">Gasto NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_gasto"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Mismo aislamiento por compañía para cotizaciones y sus líneas. -->
        <record id="rule_l10n_pe_ne_cotizacion_company" model="ir.rule">
            <field name="name">Cotización NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_cotizacion"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_cotizacion_line_company" model="ir.rule">
            <field name="name">Línea de cotización NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_cotizacion_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_l10n_pe_ne_caja_sesion_company" model="ir.rule">
            <field name="name">Caja NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_caja_sesion"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_caja_movimiento_company" model="ir.rule">
            <field name="name">Movimiento de caja NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_caja_movimiento"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_l10n_pe_ne_lote_company" model="ir.rule">
            <field name="name">Lote masivo NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_lote"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_lote_fila_company" model="ir.rule">
            <field name="name">Fila de lote masivo NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_lote_fila"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Aislamiento multi-compañía para guías de remisión y sus líneas. -->
        <record id="rule_l10n_pe_ne_guia_company" model="ir.rule">
            <field name="name">Guía de remisión: multi-compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_guia_remision"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_guia_line_company" model="ir.rule">
            <field name="name">Bien de guía: multi-compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_guia_remision_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Vehículos/conductores PROPIOS de una guía (o2m con flag principal, distinto
             de los maestros "frecuentes" l10n_pe_ne.vehiculo/conductor de más abajo). -->
        <record id="rule_l10n_pe_ne_guia_vehiculo_company" model="ir.rule">
            <field name="name">Vehículo de guía: multi-compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_guia_remision_vehiculo"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_guia_conductor_company" model="ir.rule">
            <field name="name">Conductor de guía: multi-compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_guia_remision_conductor"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Aislamiento multi-compañía para los maestros frecuentes de la GRE
             (vehículos y conductores): mismo patrón que guía de remisión. -->
        <record id="rule_l10n_pe_ne_vehiculo_company" model="ir.rule">
            <field name="name">Vehículo frecuente NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_vehiculo"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_conductor_company" model="ir.rule">
            <field name="name">Conductor frecuente NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_conductor"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Aislamiento multi-compañía para los establecimientos anexos del
             emisor (GRE): mismo patrón que vehículo/conductor. -->
        <record id="rule_l10n_pe_ne_establecimiento_company" model="ir.rule">
            <field name="name">Establecimiento NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_establecimiento"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
    </data>
</odoo>
