<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Grupo de la app NE Express. Implica el grupo Contable de Odoo
            (account.group_account_user), del que HEREDA los permisos para
            crear/editar facturas, pagos, clientes y productos + la
            reconciliación que usan retención/percepción.

            Aislamiento por compañía/RUC: lo aplican las reglas multi-compañía
            NATIVAS de Odoo (filtran account.move/account.payment/res.partner/
            product por company_id ∈ compañías permitidas, y manejan
            correctamente los registros compartidos company_id=False). NO se
            redefinen aquí para no romper ese manejo de compartidos; para el
            SaaS multi-RUC basta dar de alta 1 res.company por RUC y atar cada
            usuario emisor a la suya.
        -->
        <record id="group_l10n_pe_ne_emisor" model="res.groups">
            <field name="name">Emisor NE Express</field>
            <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="api_key_duration">365</field>
            <field name="comment">Puede emitir/anular comprobantes electrónicos y gestionar clientes/productos vía la API de NE Express (controller /ne/api). Hereda el grupo Contable; el aislamiento por RUC lo aplican las reglas multi-compañía nativas.</field>
        </record>

        <!--
            Aislamiento multi-compañía del modelo propio l10n_pe_ne.gasto (regla
            GLOBAL: aplica a todos). Maneja company_id=False (compartidos) igual
            que las reglas nativas. Sin esto, los gastos serían visibles entre RUC.
        -->
        <record id="rule_l10n_pe_ne_gasto_company" model="ir.rule">
            <field name="name">Gasto NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_gasto"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Mismo aislamiento por compañía para cotizaciones y sus líneas. -->
        <record id="rule_l10n_pe_ne_cotizacion_company" model="ir.rule">
            <field name="name">Cotización NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_cotizacion"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_cotizacion_line_company" model="ir.rule">
            <field name="name">Línea de cotización NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_cotizacion_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_l10n_pe_ne_caja_sesion_company" model="ir.rule">
            <field name="name">Caja NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_caja_sesion"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_caja_movimiento_company" model="ir.rule">
            <field name="name">Movimiento de caja NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_caja_movimiento"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_l10n_pe_ne_lote_company" model="ir.rule">
            <field name="name">Lote masivo NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_lote"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        <record id="rule_l10n_pe_ne_lote_fila_company" model="ir.rule">
            <field name="name">Fila de lote masivo NE Express: aislamiento por compañía</field>
            <field name="model_id" ref="model_l10n_pe_ne_lote_fila"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
    </data>
</odoo>
