<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- P6 (validez vinculante): marca 'vencida' las cotizaciones aceptadas/enviadas que pasaron su
         validez. Diario. Idempotente. noupdate para no re-armar el cron en cada -u. -->
    <record id="cron_cotizacion_vencer" model="ir.cron">
      <field name="name">NE Express: vencer cotizaciones</field>
      <field name="model_id" ref="l10n_pe_ne_biller.model_l10n_pe_ne_cotizacion"/>
      <field name="state">code</field>
      <field name="code">model._l10n_pe_ne_cron_vencer()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active" eval="True"/>
    </record>
  </data>
</odoo>
