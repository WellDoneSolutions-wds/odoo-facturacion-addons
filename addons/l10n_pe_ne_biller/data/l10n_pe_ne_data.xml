<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
  <!-- Correlativo de la Comunicación de Baja (RA): único por día por emisor. Una secuencia global
       garantiza unicidad por fecha (cada día usa un subconjunto disjunto de correlativos). -->
  <record id="seq_l10n_pe_ne_ra" model="ir.sequence">
    <field name="name">Comunicación de Baja SUNAT (RA)</field>
    <field name="code">l10n_pe.ne.ra</field>
    <field name="padding">1</field>
    <field name="number_increment">1</field>
    <field name="implementation">no_gap</field>
  </record>
  <!-- Correlativo del Resumen Diario de Boletas (RC): anula boletas (tipEstado 3). Serie propia. -->
  <record id="seq_l10n_pe_ne_rc" model="ir.sequence">
    <field name="name">Resumen Diario de Boletas SUNAT (RC)</field>
    <field name="code">l10n_pe.ne.rc</field>
    <field name="padding">1</field>
    <field name="number_increment">1</field>
    <field name="implementation">no_gap</field>
  </record>
  <!-- URL base del microservicio ms-ne-biller. Editable en Ajustes > Técnico > Parámetros del sistema.
       El código usa este parámetro (clave l10n_pe_ne_biller.url) con localhost:8090 como respaldo. -->
  <record id="param_l10n_pe_ne_biller_url" model="ir.config_parameter">
    <field name="key">l10n_pe_ne_biller.url</field>
    <field name="value">http://localhost:8090</field>
  </record>
</odoo>
