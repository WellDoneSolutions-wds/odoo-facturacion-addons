<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_company_form_l10n_pe_ne" model="ir.ui.view">
    <field name="name">res.company.form.l10n.pe.ne</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
      <field name="vat" position="after">
        <field name="l10n_pe_ne_cuenta_detraccion"/>
        <field name="l10n_pe_ne_api_key" password="True"/>
      </field>
    </field>
  </record>

  <!-- Modelo multi-DB: 1 empresa = 1 base. Se quitan los botones Crear/Eliminar de
       la lista de empresas (se conserva ver/editar la empresa propia). El backstop
       duro es el override de res.company.create en el addon. -->
  <record id="base.action_res_company_form" model="ir.actions.act_window">
    <field name="context">{'create': False, 'delete': False}</field>
  </record>
</odoo>
