<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reporte PDF de la cotización (QWeb). Usa el layout externo de Odoo, así que
         hereda el membrete/pie de la compañía emisora. -->
    <record id="action_report_cotizacion" model="ir.actions.report">
        <field name="name">Cotización</field>
        <field name="model">l10n_pe_ne.cotizacion</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_pe_ne_biller.report_cotizacion</field>
        <field name="report_file">l10n_pe_ne_biller.report_cotizacion</field>
        <field name="print_report_name">'Cotizacion - %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_l10n_pe_ne_cotizacion"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Representación impresa de la cotización. Layout propio (web.basic_layout, sin el
         membrete genérico de Odoo) con logo, panel destacado y tabla estilizada — al nivel
         de la factura. Colores: violeta de marca #5046E4. -->
    <template id="report_cotizacion">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, Helvetica, sans-serif; color:#1f2937; font-size:12px;">
                        <t t-set="sym" t-value="o.currency_id.symbol or o.currency_id.name"/>

                        <!-- Cabecera: emisor (logo + datos) · panel COTIZACIÓN -->
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="vertical-align:top; width:58%;">
                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="max-height:66px; max-width:230px; margin-bottom:8px;"/>
                                    <div style="font-size:15px; font-weight:bold;" t-esc="o.company_id.name"/>
                                    <div t-if="o.company_id.vat" style="font-size:11px; color:#6b7280;">RUC: <span t-esc="o.company_id.vat"/></div>
                                    <div t-if="o.company_id.street" style="font-size:11px; color:#6b7280;">
                                        <span t-esc="o.company_id.street"/><t t-if="o.company_id.city">, <span t-esc="o.company_id.city"/></t>
                                    </div>
                                    <div t-if="o.company_id.phone or o.company_id.email" style="font-size:11px; color:#6b7280;">
                                        <t t-if="o.company_id.phone">Tel: <span t-esc="o.company_id.phone"/></t>
                                        <t t-if="o.company_id.phone and o.company_id.email"> · </t>
                                        <t t-if="o.company_id.email"><span t-esc="o.company_id.email"/></t>
                                    </div>
                                </td>
                                <td style="vertical-align:top; width:42%; text-align:right;">
                                    <div style="display:inline-block; border:1.5px solid #5046E4; border-radius:10px; padding:12px 20px; text-align:center; min-width:210px;">
                                        <div style="color:#5046E4; font-weight:bold; font-size:16px; letter-spacing:.6px;">COTIZACIÓN</div>
                                        <div style="font-size:15px; font-weight:bold; margin-top:2px;" t-esc="o.name"/>
                                        <div style="border-top:1px solid #e6e8f2; margin:8px 0 6px;"/>
                                        <table style="width:100%; font-size:11px; color:#4b5563;">
                                            <tr><td style="text-align:left; color:#8b90a0;">Fecha</td><td style="text-align:right;"><span t-field="o.fecha"/></td></tr>
                                            <tr><td style="text-align:left; color:#8b90a0;">Validez</td><td style="text-align:right;"><span t-esc="o.validez_dias"/> día(s)</td></tr>
                                            <tr><td style="text-align:left; color:#8b90a0;">Moneda</td><td style="text-align:right;"><span t-esc="o.currency_id.name"/></td></tr>
                                            <tr t-if="o.create_uid"><td style="text-align:left; color:#8b90a0;">Atendido por</td><td style="text-align:right;"><span t-esc="o.create_uid.name"/></td></tr>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Cliente -->
                        <div style="margin-top:20px; background:#f5f6fb; border:1px solid #e6e8f2; padding:11px 15px; border-radius:8px;">
                            <div style="font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:#8b90a0; margin-bottom:2px;">Cliente</div>
                            <div style="font-weight:bold;"><span t-field="o.partner_id.name"/><t t-if="o.partner_id.vat"> · <span t-esc="o.partner_id.vat"/></t></div>
                            <div t-if="o.partner_id.street" style="font-size:11px; color:#6b7280;" t-field="o.partner_id.street"/>
                        </div>

                        <!-- Detalle -->
                        <table style="width:100%; border-collapse:collapse; margin-top:18px; font-size:12px;">
                            <thead>
                                <tr style="background:#5046E4; color:#ffffff;">
                                    <th style="text-align:center; padding:8px 6px; width:28px; border-radius:6px 0 0 0;">N°</th>
                                    <th style="text-align:left; padding:8px 10px;">Descripción</th>
                                    <th style="text-align:right; padding:8px 8px; width:54px;">Cant.</th>
                                    <th style="text-align:center; padding:8px 8px; width:50px;">Und.</th>
                                    <th style="text-align:right; padding:8px 8px; width:92px;">P. Unit.</th>
                                    <th style="text-align:right; padding:8px 8px; width:52px;">Desc.</th>
                                    <th style="text-align:right; padding:8px 10px; width:104px; border-radius:0 6px 0 0;">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="l"
                                    t-att-style="'border-bottom:1px solid #eef0f6;' + ('background:#fafbfe;' if l_index % 2 else '')">
                                    <td style="text-align:center; padding:7px 6px; color:#9aa0b0;" t-esc="l_index + 1"/>
                                    <td style="padding:7px 10px;">
                                        <span t-esc="l.descripcion"/>
                                        <t t-if="not l.afecto_igv"><span style="font-size:10px; color:#9aa0b0;"> (no gravado)</span></t>
                                        <div t-if="l.product_id.default_code" style="font-size:10px; color:#9aa0b0;">Cód.: <span t-esc="l.product_id.default_code"/></div>
                                    </td>
                                    <td style="text-align:right; padding:7px 8px;" t-esc="'%.2f' % l.cantidad"/>
                                    <td style="text-align:center; padding:7px 8px; color:#6b7280;" t-esc="l.product_id.l10n_pe_ne_unit_code or 'NIU'"/>
                                    <td style="text-align:right; padding:7px 8px;"><span t-esc="sym"/> <span t-esc="'%.2f' % l.precio_unitario"/></td>
                                    <td style="text-align:right; padding:7px 8px; color:#6b7280;" t-esc="(str(int(round(l.descuento))) + '%') if l.descuento else '—'"/>
                                    <td style="text-align:right; padding:7px 10px; font-weight:600;"><span t-esc="sym"/> <span t-esc="'%.2f' % l.subtotal"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Notas + totales -->
                        <table style="width:100%; margin-top:18px; border-collapse:collapse;">
                            <tr>
                                <td style="vertical-align:top; width:56%; padding-right:20px;">
                                    <!-- Condiciones comerciales -->
                                    <t t-if="o.forma_pago or o.tiempo_entrega or o.garantia">
                                        <div style="font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:#8b90a0; margin-bottom:3px;">Condiciones</div>
                                        <table style="font-size:11px; color:#4b5563; margin-bottom:8px;">
                                            <tr t-if="o.forma_pago"><td style="color:#8b90a0; padding-right:8px;">Forma de pago</td><td style="font-weight:600;" t-esc="o.forma_pago"/></tr>
                                            <tr t-if="o.tiempo_entrega"><td style="color:#8b90a0; padding-right:8px;">Tiempo de entrega</td><td style="font-weight:600;" t-esc="o.tiempo_entrega"/></tr>
                                            <tr t-if="o.garantia"><td style="color:#8b90a0; padding-right:8px;">Garantía</td><td style="font-weight:600;" t-esc="o.garantia"/></tr>
                                        </table>
                                    </t>
                                    <t t-if="o.notas">
                                        <div style="font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:#8b90a0; margin-bottom:3px;">Notas</div>
                                        <div style="font-size:11px; color:#4b5563; white-space:pre-line;" t-esc="o.notas"/>
                                    </t>
                                </td>
                                <td style="vertical-align:top; width:44%;">
                                    <table style="width:100%; font-size:12px;">
                                        <tr t-if="o.amount_op_gravada"><td style="padding:3px 0; color:#6b7280;">Op. gravada</td><td style="text-align:right;"><span t-esc="sym"/> <span t-esc="'%.2f' % o.amount_op_gravada"/></td></tr>
                                        <tr t-if="o.amount_op_no_gravada"><td style="padding:3px 0; color:#6b7280;">Op. exonerada / inafecta</td><td style="text-align:right;"><span t-esc="sym"/> <span t-esc="'%.2f' % o.amount_op_no_gravada"/></td></tr>
                                        <tr><td style="padding:3px 0; color:#6b7280;">Valor venta</td><td style="text-align:right;"><span t-esc="sym"/> <span t-esc="'%.2f' % o.amount_untaxed"/></td></tr>
                                        <tr><td style="padding:3px 0; color:#6b7280;">IGV (18%)</td><td style="text-align:right;"><span t-esc="sym"/> <span t-esc="'%.2f' % o.amount_tax"/></td></tr>
                                        <tr style="border-top:2px solid #5046E4;">
                                            <td style="padding:7px 0; font-weight:bold; font-size:14px;">Total <span t-esc="o.currency_id.name"/></td>
                                            <td style="text-align:right; padding:7px 0; font-weight:bold; font-size:14px; color:#5046E4;"><span t-esc="sym"/> <span t-esc="'%.2f' % o.amount_total"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Importe en letras -->
                        <div style="margin-top:12px; background:#f5f6fb; border:1px solid #e6e8f2; border-radius:8px; padding:8px 14px; font-size:11px;">
                            <span style="color:#8b90a0; text-transform:uppercase; letter-spacing:.06em;">Son:</span>
                            <span style="font-weight:600;" t-esc="o.l10n_pe_ne_importe_en_letras()"/>
                        </div>

                        <!-- Datos de pago (cuentas bancarias del emisor) -->
                        <div t-if="o.company_id.l10n_pe_ne_datos_pago"
                             style="margin-top:14px; border:1px solid #e6e8f2; border-left:3px solid #5046E4; border-radius:8px; padding:10px 15px;">
                            <div style="font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:#5046E4; font-weight:600; margin-bottom:4px;">Datos de pago</div>
                            <div style="font-size:11px; color:#374151; white-space:pre-line;" t-esc="o.company_id.l10n_pe_ne_datos_pago"/>
                        </div>

                        <!-- Pie -->
                        <div style="margin-top:30px; border-top:1px solid #eef0f6; padding-top:10px; font-size:10px; color:#9aa0b0; text-align:center;">
                            Documento referencial. Una cotización NO es un comprobante de pago electrónico y no tiene validez tributaria ante SUNAT.
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
