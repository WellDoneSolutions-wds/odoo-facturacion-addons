<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Parámetros base de NE Express. Aquí NO se siembra ningún usuario emisor ni
        credencial por defecto: cada emisor se da de alta por RUC vía
        res.company.l10n_pe_ne_provision_tenant (endpoint /ne/api/admin/tenants),
        con su propio login y contraseña.
    -->
    <data noupdate="1">
        <!--
            TTL (horas) de la API key que emite el login de NE Express. Editable en
            caliente desde Ajustes → Técnico → Parámetros del sistema, sin redeploy.
            noupdate: si lo cambias, un -u del módulo no lo pisa.
        -->
        <record id="param_ne_token_ttl_hours" model="ir.config_parameter">
            <field name="key">l10n_pe_ne.token_ttl_hours</field>
            <field name="value">12</field>
        </record>
    </data>
</odoo>
